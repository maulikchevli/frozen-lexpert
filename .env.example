# Copy to `.env` and edit to your local paths, then `source .env`
# (or export these in your shell). The Hydra configs read them as
# ${oc.env:RADCHEST_ROOT} etc. at run time.

# RadChestCT root: contains json/, CT_Scan_Metadata_Complete_35747.csv,
# and label_categories_refined.json
export RADCHEST_ROOT=/path/to/RadChestCT

# CT-RATE root: contains validation/ and reports/
export CTRATE_ROOT=/path/to/ct_rate

# CT-RATE metadata CSV carrying the DICOM rescale slope/intercept
# (the CT-CHAT validation_metadata.csv)
export CTRATE_META=/path/to/ct_rate/validation_metadata.csv

# Output root for embedding caches, pools, and bootstraps (default: ./results)
export CTFM_RESULTS=./results
